# Supabase — copia estos valores desde https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Solo en servidor (NO empieza por NEXT_PUBLIC). Usado para tareas admin (crear allowed_emails, etc.)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# IA (opcional, solo necesario para importar recetas desde URL o YouTube — fases 3 y 5).
# Usamos Groq (Llama 3.3 70B), gratis y sin tarjeta.
# Crea una clave en https://console.groq.com/keys
GROQ_API_KEY=
